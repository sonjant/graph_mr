/*
 * Graph MR Nextflow config – plug-and-play (genotype + one post-genotype dataset).
 * Run from pipeline root: nextflow run nextflow/main.nf -c nextflow/nextflow.config
 * Override with -params-file or --param.key=value.
 */

nextflow.enable.dsl = 2

params {
  root           = ''   // required: pipeline root (graph_mr_github)
  genotype_dir   = ''   // required: PLINK + merged.pruned.eigenvec
  vcf_dir        = ''   // required for 02.8/03.7: VCF for dosages
  dataset        = ''   // required: your dataset name (e.g. proteomics, mydata)
  primary_method = 'cftlmr'
  method_types   = 'cftlmr,cfmr'
  data_dir       = ''   // optional: default ${root}/data
  ephemeral_dir  = ''   // optional: default ${root}/ephemeral
  results_dir    = ''   // optional: default ${root}/results

  // Optional: run generic preprocessing before pipeline
  run_preprocess   = false
  exposure_matrix  = ''
  covariate_file   = ''
  exposure_metadata = ''
}

// Process defaults (tune for your cluster or local)
process {
  cpus   = 1
  memory = '2 GB'
  time   = '1h'
  maxRetries = 0
  errorStrategy = 'terminate'
  shell  = ['/bin/bash', '-e', '-o', 'pipefail']
  beforeScript = null
}

// Optional: PBS resource overrides (uncomment and set executor = 'pbs' for HPC)
// process.withName:clean_plink_variants { time = '1h30m'; cpus = 4; memory = '8 GB' }
// process.withName:run_local_PLINK_GWAS_* { time = '72h'; cpus = 128; memory = '450 GB' }
// process.withName:run_PLINK_clumping { time = '24h'; cpus = 8; memory = '32 GB' }
// process.withName:extract_dosages|extract_dosages_tl { time = '8h'; cpus = 8; memory = '32 GB' }
// process.withName:create_cross_fitted_scores|create_transfer_learned_scores { time = '8h'; cpus = 15; memory = '300 GB' }
